{
  "name": "RnHeroUITemplate",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "ENVFILE=.env.development react-native run-android",
    "android:staging": "ENVFILE=.env.staging react-native run-android",
    "android:prod": "ENVFILE=.env.production react-native run-android",
    "ios": "ENVFILE=.env.development react-native run-ios",
    "ios:staging": "ENVFILE=.env.staging react-native run-ios",
    "ios:prod": "ENVFILE=.env.production react-native run-ios",
    "build:android:staging": "cd android && ENVFILE=.env.staging ./gradlew assembleRelease",
    "build:android:prod": "cd android && ENVFILE=.env.production ./gradlew assembleRelease",
    "build:ios:staging": "ENVFILE=.env.staging react-native run-ios --mode Release",
    "build:ios:prod": "ENVFILE=.env.production react-native run-ios --mode Release",
    "start": "react-native start",
    "start:reset": "react-native start --reset-cache",
    "lint": "eslint .",
    "tsc": "tsc --noEmit",
    "test": "jest",
    "postinstall": "patch-package",
    "pf": "git add -A && git commit --am --no-edit && git push origin HEAD -f"
  },
  "dependencies": {
    "@gorhom/bottom-sheet": "^5.2.14",
    "@hookform/resolvers": "^5.4.0",
    "@notifee/react-native": "^9.1.8",
    "@op-engineering/op-sqlite": "^16.2.1",
    "@react-native/new-app-screen": "0.85.3",
    "@react-navigation/bottom-tabs": "^7.16.2",
    "@react-navigation/native": "^7.2.5",
    "@react-navigation/native-stack": "^7.16.0",
    "@tanstack/react-query": "^5.100.14",
    "axios": "^1.16.1",
    "heroui-native": "^1.0.4",
    "i18next": "^26.3.1",
    "lucide-react-native": "^1.18.0",
    "react": "19.2.3",
    "react-hook-form": "^7.76.1",
    "react-i18next": "^17.0.8",
    "react-native": "0.85.3",
    "react-native-config": "^1.6.1",
    "react-native-gesture-handler": "^3.0.0",
    "react-native-gifted-charts": "^1.4.77",
    "react-native-haptic-feedback": "^3.0.0",
    "react-native-localize": "^3.7.0",
    "react-native-mmkv": "^4.3.1",
    "react-native-nitro-modules": "^0.35.9",
    "react-native-reanimated": "^4.4.0",
    "react-native-safe-area-context": "^5.8.0",
    "react-native-screens": "^4.25.2",
    "react-native-svg": "^15.15.5",
    "react-native-ui-datepicker": "^3.3.0",
    "react-native-worklets": "^0.9.1",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "uniwind": "^1.7.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.1.0",
    "@react-native-community/cli-platform-android": "20.1.0",
    "@react-native-community/cli-platform-ios": "20.1.0",
    "@react-native/babel-preset": "0.85.3",
    "@react-native/eslint-config": "0.85.3",
    "@react-native/jest-preset": "0.85.3",
    "@react-native/metro-config": "0.85.3",
    "@react-native/typescript-config": "0.85.3",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.2.0",
    "@types/react-test-renderer": "^19.1.0",
    "babel-plugin-module-resolver": "^5.0.3",
    "eslint": "^8.19.0",
    "eslint-config-prettier": "^9",
    "eslint-plugin-prettier": "^5",
    "jest": "^29.6.3",
    "patch-package": "^8.0.1",
    "postinstall-postinstall": "^2.1.0",
    "prettier": "2.8.8",
    "react-native-svg-transformer": "^1.5.3",
    "react-test-renderer": "19.2.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">= 22.11.0"
  }
}
