{
  "extends": "@react-native/typescript-config",
  "compilerOptions": {
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@api/*": ["src/api/*"],
      "@assets/*": ["src/assets/*"],
      "@components/*": ["src/components/*"],
      "@hooks/*": ["src/hooks/*"],
      "@navigation/*": ["src/navigation/*"],
      "@screens/*": ["src/screens/*"],
      "@store/*": ["src/store/*"],
      "@theme/*": ["src/theme/*"],
      "@app-types/*": ["src/types/*"],
      "@utils/*": ["src/utils/*"],
      "@config/*": ["src/config/*"],
      "@features/*": ["src/features/*"],
      "@i18n/*": ["src/i18n/*"],
      "uniwind": ["node_modules/uniwind/dist/module/index.d.ts"],
      "uniwind/*": ["node_modules/uniwind/dist/*"]
    }
  },
  "exclude": ["node_modules", "__tests__", "ios", "android", "vendor"]
}
